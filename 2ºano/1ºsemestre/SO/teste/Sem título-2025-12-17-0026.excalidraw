      "type": "text",
      "x": 520.3871263776505,
      "y": 5242.857142857142,
      "width": 287.5,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
