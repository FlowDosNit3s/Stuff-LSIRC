      "boundElements": [],
      "updated": 1765931030993,
      "link": null,
      "locked": false,
      "text": "Para resolver este exercício, precisamos simular o algoritmo SRTF (Shortest\nRemaining Time First), que é a versão preemptiva do SJF (Shortest Job First).\nIsto significa que, a cada instante em que chega um novo processo ou um\nprocesso termina, o sistema escolhe executar o processo que tem o menor\ntempo restante para completar.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Para resolver este exercício, precisamos simular o algoritmo SRTF (Shortest Remaining Time First), que é a versão preemptiva do SJF (Shortest Job First).\nIsto significa que, a cada instante em que chega um novo processo ou um processo termina, o sistema escolhe executar o processo que tem o menor tempo restante para completar.",
      "autoResize": false,
      "lineHeight": 1.25
    }
