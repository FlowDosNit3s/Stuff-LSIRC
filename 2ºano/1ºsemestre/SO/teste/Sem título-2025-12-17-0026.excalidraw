      "seed": 1561810070,
      "version": 250,
      "versionNonce": 990307722,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1765929209363,
      "link": null,
      "locked": false,
      "text": "PO: (4,3,3) - (0,0,2) = (4,3,1)\nP1: (2,6,2) - (2,4,1) = (0,2,1)\nP2: (9,0,2) - (3,0,2) = (6,0,0)\nP3: (3,2,2) - (2,0,0) = (1,2,2)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PO: (4,3,3) - (0,0,2) = (4,3,1)\nP1: (2,6,2) - (2,4,1) = (0,2,1)\nP2: (9,0,2) - (3,0,2) = (6,0,0)\nP3: (3,2,2) - (2,0,0) = (1,2,2)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "BwWES3jpuz8bCvgicNyiS",
